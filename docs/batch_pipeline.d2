direction: right

title: {
  label: Batch Pipeline (meld run)
  near: top-center
  shape: text
  style.font-size: 24
  style.bold: true
}

# ---------------------------------------------------------------------------
# Stages
# ---------------------------------------------------------------------------

load_config: Load Config {
  style.fill: "#fef7e0"
  style.border-radius: 6
  label: "Load Config\n\n1 thread"
}

load_a: Load A Dataset {
  style.fill: "#e8f8e8"
  style.border-radius: 6
  label: "Load A Dataset\n(CSV/JSONL/Parquet)\n\n1 thread"
}

build_a_index: Build A Index {
  style.fill: "#f3e8ff"
  style.border-radius: 6
  label: "Build/Load A\nEmbedding Index\n(ONNX encode x 256 batch)\n\n1 thread\n(or skip if cached)"
}

load_b: Load B Dataset {
  style.fill: "#e8f8e8"
  style.border-radius: 6
  label: "Load B Dataset\n\n1 thread"
}

build_b_index: Build B Index {
  style.fill: "#f3e8ff"
  style.border-radius: 6
  label: "Build/Load B\nEmbedding Index\n(ONNX encode x 256 batch)\n\n1 thread\n(or skip if cached)"
}

build_blocking: Build Blocking {
  style.fill: "#e0f0ff"
  style.border-radius: 6
  label: "Build A\nBlocking Index\n\n1 thread"
}

# ---------------------------------------------------------------------------
# Sync barrier before parallel scoring
# ---------------------------------------------------------------------------

barrier: SYNC {
  shape: diamond
  style.fill: "#ffdddd"
  label: "all data\nready"
}

# ---------------------------------------------------------------------------
# Parallel scoring
# ---------------------------------------------------------------------------

score: Score B Records {
  style.fill: "#fff0e0"
  style.border-radius: 6
  style.stroke: "#e65100"
  style.stroke-width: 2
  label: |md
    Score all B records
    (rayon par_iter)

    **N threads (unbounded)**

    per record:
    1. skip if in crossmap
    2. blocking query
    3. ANN / vector search
    4. score candidates
    5. crossmap.claim()
  |
}

# ---------------------------------------------------------------------------
# Sync barrier after scoring
# ---------------------------------------------------------------------------

barrier2: SYNC {
  shape: diamond
  style.fill: "#ffdddd"
  label: "all scored"
}

# ---------------------------------------------------------------------------
# Output
# ---------------------------------------------------------------------------

output: Write Output {
  style.fill: "#e8f0fe"
  style.border-radius: 6
  label: "Write CSVs +\nSave CrossMap\n\n1 thread"
}

# ---------------------------------------------------------------------------
# Flow
# ---------------------------------------------------------------------------

load_config -> load_a -> build_a_index
build_a_index -> load_b -> build_b_index -> build_blocking
build_blocking -> barrier
barrier -> score
score -> barrier2
barrier2 -> output
