direction: down

title: {
  label: Melder Architecture
  near: top-center
  shape: text
  style.font-size: 28
  style.bold: true
}

# ---------------------------------------------------------------------------
# Input layer
# ---------------------------------------------------------------------------
config: YAML Config {shape: page}
datasets: Datasets (CSV / JSONL / Parquet) {shape: page}

# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------
cli: meld CLI {
  style.fill: "#e8f0fe"
  style.border-radius: 8
  batch: batch (run)
  live: live (serve)
}

config -> cli
datasets -> cli

# ---------------------------------------------------------------------------
# Core engine (shared)
# ---------------------------------------------------------------------------
engine: Matching Engine {
  style.fill: "#f3e8ff"
  style.border-radius: 8

  encoder: Embedding Encoder {
    label: "Embedding Encoder\nONNX (fastembed)\nPooled sessions, text-hash skip"
  }
  vector_index: Vector Index {
    label: "Vector Index\nFlat (brute-force) or HNSW (usearch)\nCached to disk, f32/f16/bf16"
  }
  blocking: Blocking {
    label: "Blocking\nAND/OR field constraints\nnarrows candidate set"
  }
  scoring: Scoring {
    label: "Scoring\nexact + fuzzy + embedding + numeric\nweighted sum -> classify"
  }

  encoder -> vector_index: combined embedding
  vector_index -> blocking
  blocking -> scoring: candidates
}

cli.batch -> engine
cli.live -> engine

# ---------------------------------------------------------------------------
# Batch mode output
# ---------------------------------------------------------------------------
batch_output: Batch Output {
  style.fill: "#e8f0fe"
  style.border-radius: 8

  results: Results CSV {shape: page}
  review: Review CSV {shape: page}
  unmatched: Unmatched CSV {shape: page}
}

# ---------------------------------------------------------------------------
# Live mode specifics
# ---------------------------------------------------------------------------
live_layer: Live Mode {
  style.fill: "#fce8e8"
  style.border-radius: 8

  api: HTTP API (axum) {
    label: "REST API\nupsert / match / remove\nconfirm / break / lookup\nhealth / status"
  }
  wal: Write-Ahead Log {
    label: "WAL\ndurability + replay on restart"
  }
  wal_file: WAL File (NDJSON) {shape: page}
  wal -> wal_file: append
}

cli.live -> live_layer.api

# ---------------------------------------------------------------------------
# CrossMap (shared state)
# ---------------------------------------------------------------------------
crossmap: CrossMap {
  label: "CrossMap\nbidirectional A <-> B mapping\natomic claim / break"
  style.fill: "#e8f8e8"
  style.border-radius: 8

  mem: In-Memory Map
  csv: CrossMap CSV {shape: page}
  mem -> csv: persist
}

# ---------------------------------------------------------------------------
# Connections
# ---------------------------------------------------------------------------
engine -> batch_output: batch results
engine -> crossmap.mem: claim best match
live_layer.api -> engine: per-request
live_layer.api -> crossmap.mem: confirm / break
live_layer.api -> live_layer.wal: append events
crossmap.mem -> batch_output: matched pairs
