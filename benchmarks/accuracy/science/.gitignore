# Science experiments — gitignore
#
# The scientific record lives in:
#   *.py, *.md, config.yaml          — code + narrative
#   master/, holdout/                 — fixed evaluation datasets (committed)
#   results/*/metrics.csv             — experiment summary tables
#   results/*/learning_curve.png      — training trajectory charts
#   results/experiment_6/sweep_results.csv
#
# Everything else is regenerable by re-running experiments.
# See experiments.md for exact commands. Run setup_datasets.py first
# to regenerate the round training datasets from the committed master.

# ---- Model weights (~28 GB across all experiments) ----
# Regenerated by the training loop: finetune.py → export.py
results/*/models/
results/*/model/

# ---- Per-round working data ----
# Regenerated by run.py (meld run → evaluate → extract pairs)
results/*/work/
results/*/holdout/

# ---- Experiment 6 BM25 sweep data ----
# Regenerated by run_experiment6.py (requires experiment 5 model)
results/experiment_6/bm25_*/
results/experiment_6/dataset_*.csv
results/experiment_6/cache/
results/experiment_6/shared_cache/

# ---- Round training datasets (~25 MB) ----
# Regenerated by setup_datasets.py from committed master/dataset_a.csv
rounds/

# ---- Python bytecode ----
__pycache__/
