# Generated outputs — never commit
**/cache/*
!**/cache/.gitkeep
**/output/*
!**/output/.gitkeep
**/wal/*.ndjson
!**/wal/.gitkeep
**/crossmap.csv

# SQLite databases (live mode artifacts)
**/*.db

# Embedding index artifacts (usearch, flat, manifests, texthash)
**/*.usearch
**/*.usearchdb/
**/*.index
**/*.index.manifest
**/*.index.texthash
**/manifest.json

# Emacs lockfiles
\#*\#

# Datasets are large — not committed; regenerate with: python3 benchmarks/data/generate.py
data/*.csv
data/*.jsonl
data/*.parquet
!data/generate.py
