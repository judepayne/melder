# ---- Regenerable artifacts (never commit) ----
**/cache/
**/output/
**/wal/*.ndjson
**/crossmap.csv

# SQLite databases
**/*.db

# Embedding / vector index artifacts
**/*.usearch
**/*.usearchdb/
**/*.index
**/*.index.manifest
**/*.index.texthash
**/manifest.json

# Emacs lockfiles
\#*\#

# ---- Datasets ----
# Only 10k datasets are committed (small, needed for unit tests).
# Larger datasets must be regenerated: python3 benchmarks/data/generate.py --size N

# Exclude all generated data by default
data/*.csv
data/*.jsonl
data/*.parquet

# Re-include 10k datasets and their ground truth (small enough to commit)
!data/dataset_a_10k.csv
!data/dataset_a_10k.jsonl
!data/dataset_a_10k.parquet
!data/dataset_b_10k.csv
!data/dataset_b_10k.jsonl
!data/dataset_b_10k.parquet
!data/ground_truth_crossmap_10k.csv

# Always include the generator script
!data/generate.py
